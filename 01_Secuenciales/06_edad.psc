// Realizar un algoritmo que calcule la edad de una persona.

Algoritmo edad
	Definir fnac, factual, age como entero;
	
	Escribir "Ingresa tu ańo de nacimiento";
	leer fnac;
	
	Escribir "Ingresa el ańo actual";
	leer factual;
	
	age <- factual - fnac;
	Escribir "Su edad es de: ", age, "ańos";
	
FinAlgoritmo
